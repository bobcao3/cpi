# ── Jujutsu VCS ──────────────────────────────────────
.jj/

# ── Node.js / TypeScript ────────────────────────────
node_modules/
*.js
*.js.map
# Rails app JS sources are tracked (override global *.js)
!benchmarks/tb_web_monitor/**/*.js
!benchmarks/tb_web_monitor/config/importmap.rb
*.d.ts
tsconfig.tsbuildinfo
.npm/
.pnpm-store/
# bun is the package manager — no npm lockfile
package-lock.json

# ── Environment & secrets ────────────────────────────
.env
.env.*
!.env.example
fallback-providers.json
*.pem
*.key

# ── Logs ────────────────────────────────────────────
*.log
npm-debug.log*

# ── OS files ────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editor / IDE ────────────────────────────────────
*.swp
*.swo
*~
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ── Misc ────────────────────────────────────────────
/.cache/
/.tmp/
/tmp/

# minisign signatures are release assets (never committed); secret lives in ~/.ssh/ + Actions secret
*.minisig
